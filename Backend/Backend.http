@Backend_HostAddress = http://localhost:8080
@AccessToken = replace-with-token-from-auth-response
@MatchToken = replace-with-token-from-create-match-response

GET {{Backend_HostAddress}}/health
Accept: application/json

###

POST {{Backend_HostAddress}}/v1/auth/dev
Content-Type: application/json

{
  "devId": "dev-client-1",
  "displayName": "Dev 1"
}

###

POST {{Backend_HostAddress}}/v1/matches/local-dev-match-1/server-ready
Content-Type: application/json

{
  "edgegapDeploymentId": "",
  "port": 5000
}

###

POST {{Backend_HostAddress}}/v1/matches/create
Authorization: Bearer {{AccessToken}}
Content-Type: application/json

{
  "roomName": "local-dev-match-1",
  "mapName": "Classic Garden",
  "maxPlayers": 4,
  "characterId": 1,
  "displayName": "Dev 1"
}

###

POST {{Backend_HostAddress}}/v1/matches/local-dev-match-1/validate-player
Content-Type: application/json

{
  "matchId": "local-dev-match-1",
  "matchToken": "{{MatchToken}}",
  "playerAccessToken": "{{AccessToken}}",
  "characterId": 1,
  "catalogIndex": 0,
  "displayName": "Dev 1",
  "hp": 3,
  "bomb": 1,
  "speed": 2
}
